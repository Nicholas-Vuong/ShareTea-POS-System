{
  "name": "sharetea-monorepo",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/api",
    "apps/web"
  ],
  "scripts": {
    "dev:api": "npm run dev --workspace @sharetea/api",
    "dev:web": "npm run dev --workspace @sharetea/web",
    "dev": "npm-run-all --parallel dev:api dev:web",
    "build": "npm run build --workspace @sharetea/api && npm run build --workspace @sharetea/web",
    "lint": "npm run lint --workspaces",
    "test": "npm run test --workspaces"
  },
  "devDependencies": {
    "npm-run-all": "^4.1.5"
  }
}
