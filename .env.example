#############################################
# Sharetea SaaS Environment Variables (sample)
# Copy to .env.local (or .env) and fill values
#############################################

# Frontend API base URL
VITE_API_BASE_URL=http://localhost:3000

# External APIs used by the frontend
VITE_FOODDATA_API_KEY=your_usda_fooddata_api_key
VITE_WEATHERAPI_KEY=your_weatherapi_or_openweather_key

# Supabase client config (frontend)
VITE_SUPABASE_URL=your_supabase_project_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# Optional: legacy OAuth/client secrets if used elsewhere
OAUTH_CLIENT_ID=your_google_oauth_client_id
OAUTH_CLIENT_SECRET=your_google_oauth_client_secret
SUPABASE_DATABASE_PASSWORD=your_supabase_db_password
